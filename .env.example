# Required: frontend Clerk key. This is baked into the frontend build.
VITE_CLERK_PUBLISHABLE_KEY=pk_live_replace_me

# Required: backend Clerk secret used to verify session tokens.
CLERK_SECRET_KEY=sk_live_replace_me

# Required: comma-separated browser origins allowed by Clerk token azp validation.
# For local debugging, set this to the exact localhost origin you will open.
CLERK_AUTHORIZED_PARTIES=http://127.0.0.1:8080

# Recommended for containers with a persistent volume.
# AGENT_VIEWER_DATA_DIR=/data

# Platform-provided in Railway. Do not hardcode these there unless you know why.
# PORT=8080
# RAILWAY_PUBLIC_DOMAIN=your-app-domain.up.railway.app
